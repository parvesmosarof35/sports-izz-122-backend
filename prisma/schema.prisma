// datasource and generator setup
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------
//  ENUMS
// ---------------------------------------------------------

enum UserRole {
  USER
  VENDOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

enum EveryServiceStatus {
  AVAILABLE
  BOOKED
}

enum PaymentStatus {
  PAID
  UNPAID
  REFUNDED
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  STRIPE
}

enum PromoStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum SupportType {
  Critical
  High
  Medium
  Low
}

enum SupportStatus {
  Pending
  Closed
}

// ---------------------------------------------------------
//  MODEL
// ---------------------------------------------------------

model User {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  fullName        String?
  email           String     @unique
  password        String
  profileImage    String     @default("https://i.ibb.co/Ps9gZ8DD/Profile-image.png")
  contactNumber   String?
  address         String?
  country         String?
  latitude        Float?
  longitude       Float?
  role            UserRole   @default(USER)
  status          UserStatus @default(ACTIVE)
  fcmToken        String?    @default("")
  age             Int?
  dateOfBirth     DateTime?
  gender          String?
  isEmailVerified Boolean    @default(false)
  isPhoneVerified Boolean    @default(false)

  // Stripe
  stripeAccountId   String?
  isStripeConnected Boolean @default(false)

  // notification Preferences
  supportNotification Boolean @default(true)
  paymentNotification Boolean @default(true)
  emailNotification   Boolean @default(true)

  isHotel Boolean @default(false)

  otp        String?
  otpExpiry  DateTime?
  identifier String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relationships
  payment       Payment[]
  notifications Notifications[]
  review        Review[]
  favorite      Favorite[]
  sender        Channel[]       @relation("ChannelPerson1")
  receiver      Channel[]       @relation("ChannelPerson2")
  messages      Message[]       @relation("sentMessages")
  support       Support[]
  venues        Venue[]
  venueBookings Venue_booking[]

  // gamification relationships
  userProfile      UserProfile?
  xpHistory        XPHistory[]
  userBadges       UserBadge[]
  userAchievements UserAchievement[]
  userStreaks      UserStreak[]

  @@map("users")
}

model Admin {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String?
  phoneNumber String?
  email       String  @unique
  password    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Venue {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  venueName           String
  sportsType          String
  pricePerHour        Float
  capacity            Int
  location            String
  latitude            Float?
  longitude           Float?
  venueStatus         Boolean             @default(true)
  description         String
  venueImage          String
  amenities           Json? // [{ amenityName: string, amenityImage: string }, ...]
  courtNumbers        Int[] // like input 5 --> [1, 2, 3, 4, 5]
  EveryServiceStatus  EveryServiceStatus  @default(AVAILABLE)
  venueAvailabilities VenueAvailability[]
  venueRating         String              @default("0")
  venueReviewCount    Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // relationships
  scheduleSlots ScheduleSlot[]
  vendorId      String?         @db.ObjectId
  user          User?           @relation(fields: [vendorId], references: [id])
  venueBookings Venue_booking[]
  reviews       Review[]
  payments      Payment[]

  @@map("venues")
}

model VenueAvailability {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  day       Weekday
  // multiple time slot in single date
  createdAt DateTime @default(now())

  venueId       String
  venue         Venue          @relation(fields: [venueId], references: [id])
  scheduleSlots ScheduleSlot[]

  @@map("venue_availability")
}

model ScheduleSlot {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  from String // "10:00 AM or PM"
  to   String // "12:00 AM or PM"

  // relationships
  venueId           String
  venue             Venue              @relation(fields: [venueId], references: [id])
  availableVenueId  String?            @db.ObjectId
  venueAvailability VenueAvailability? @relation(fields: [availableVenueId], references: [id])

  @@map("schedule_slots")
}

model Venue_booking {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  checkoutSessionId String?
  date              String
  day               String
  timeSlot          Json // { "from": "10:00 AM", "to": "12:00 PM" }
  courtNumber       Int
  sportsType        String
  totalPrice        Float
  bookingStatus     BookingStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // relationships
  vendorId String?   @db.ObjectId
  user     User?     @relation(fields: [userId], references: [id])
  userId   String?   @db.ObjectId
  venue    Venue?    @relation(fields: [venueId], references: [id])
  venueId  String?   @db.ObjectId
  payment  Payment[]

  @@map("venue_bookings")
}

model SportType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  sportName   String   @unique
  sportsImage String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sport_types")
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  rating     Float
  subRatings Json?
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // relationships
  user    User    @relation(fields: [userId], references: [id])
  userId  String  @db.ObjectId
  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  @@map("reviews")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("favorites")
}

model Notifications {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  receiverId   String?  @db.ObjectId
  partnerId    String?  @db.ObjectId
  supportId    String?  @db.ObjectId
  title        String
  message      String?
  body         String
  serviceTypes String?
  bookingId    String?
  read         Boolean  @default(false)
  isClicked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User?    @relation(fields: [receiverId], references: [id])

  @@map("notifications")
}

model Faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

model CustomerContact {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  email       String
  phone       String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customer_contacts")
}

model About_App {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("about_apps")
}

model Terms_Condition {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("terms_conditions")
}

model Privacy_Policy {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("privacy_policies")
}

model Channel {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  channelName String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  //Relations
  person1Id String?   @db.ObjectId
  person1   User?     @relation("ChannelPerson1", fields: [person1Id], references: [id])
  person2Id String?   @db.ObjectId
  person2   User?     @relation("ChannelPerson2", fields: [person2Id], references: [id])
  messages  Message[]

  @@map("channels")
}

model Message {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  subject   String? // no need other message
  message   String?
  files     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  senderId    String   @db.ObjectId
  sender      User     @relation("sentMessages", fields: [senderId], references: [id])
  channelName String
  Channel     Channel? @relation(fields: [channelName], references: [channelName])

  @@map("messages")
}

model Payment {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  amount            Float
  description       String?
  currency          String?
  sessionId         String?       @unique
  status            PaymentStatus
  payable_name      String?
  payable_email     String?
  paymentIntentId   String?
  country           String?
  admin_commission  Float?
  vendor_commission Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user           User           @relation(fields: [userId], references: [id])
  userId         String         @db.ObjectId
  venue          Venue?         @relation(fields: [venueId], references: [id])
  venueId        String?        @db.ObjectId
  venueBooking   Venue_booking? @relation(fields: [venueBookingId], references: [id])
  venueBookingId String?        @db.ObjectId

  @@map("payments")
}

model Support {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  fullName      String?
  email         String?
  contactNumber String?
  subject       String
  description   String
  supportType   SupportType   @default(High)
  status        SupportStatus @default(Pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  reportedUserId String? @db.ObjectId
  user           User?   @relation(fields: [userId], references: [id])
  userId         String? @db.ObjectId

  @@map("supports")
}

// ---------------------------------------------------------
//  GAMIFICATION MODELS
// ---------------------------------------------------------

enum BadgeType {
  FIRST_BOOKING
  REVIEW_MASTER
  REFER_CHAMPION
  STREAK_MASTER
  CHALLENGE_WINNER
  ELITE_USER
  VIP_MEMBER
  SPEED_BOOKER
  LOYAL_CUSTOMER
  EXPLORER
}

enum AchievementType {
  FIRST_BOOKING
  MULTIPLE_SPORTS
  REFERRAL_CHAMP
  STREAK_MASTER
  CHALLENGE_CHAMP
  ELITE_STATUS
}

enum GamificationAction {
  BOOKING
  REVIEW
  REFERRAL
  CHALLENGE_COMPLETE
  DAILY_LOGIN
}

model UserProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  currentLevel   Int      @default(1)
  currentXP      Int      @default(0)
  totalXP        Int      @default(0)
  atlasPoints    Int      @default(0)
  streakDays     Int      @default(0)
  lastActiveDate DateTime @default(now())
  bookingCount   Int      @default(0)
  reviewCount    Int      @default(0)
  referralCount  Int      @default(0)
  challengeCount Int      @default(0)
  nextLevelXP    Int      @default(100)
  levelTitle     String   @default("Beginner")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // relations
  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model XPHistory {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  xpEarned    Int
  actionType  GamificationAction
  description String?
  bonusXP     Int                @default(0)
  totalXP     Int
  createdAt   DateTime           @default(now())

  // relations
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@map("xp_history")
}

model Badge {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  description  String
  iconUrl      String
  badgeType    BadgeType
  isActive     Boolean   @default(true)
  isDeleted    Boolean   @default(false)
  xpReward     Int       @default(0)
  pointsReward Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // relations
  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  earnedAt    DateTime @default(now())
  isDisplayed Boolean  @default(true)

  // relations
  userId  String @db.ObjectId
  user    User   @relation(fields: [userId], references: [id])
  badgeId String @db.ObjectId
  badge   Badge  @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Achievement {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  description     String
  achievementType AchievementType
  targetValue     Int
  currentProgress Int             @default(0)
  isActive        Boolean         @default(true)
  xpReward        Int             @default(0)
  pointsReward    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  progress    Int       @default(0)
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  lastUpdated DateTime  @default(now())

  // Relations
  userId        String      @db.ObjectId
  user          User        @relation(fields: [userId], references: [id])
  achievementId String      @db.ObjectId
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model UserStreak {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  streakType     String // "booking", "login", "review"
  currentStreak  Int      @default(0)
  bestStreak     Int      @default(0)
  lastActiveDate DateTime @default(now())
  bonusXP        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, streakType])
  @@map("user_streaks")
}

model Level {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  level       Int      @unique
  title       String
  minXP       Int
  maxXP       Int
  benefits    Json // ["discount_5%", "priority_access", "vip_perks"]
  badgeReward String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("levels")
}

model GamificationSettings {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  xpPerBooking         Int      @default(10)
  xpPerReview          Int      @default(5)
  xpPerReferral        Int      @default(50)
  xpPerChallenge       Int      @default(25)
  xpPerDailyLogin      Int      @default(2)
  streakBonusXP        Int      @default(5)
  referralPointsReward Int      @default(10)
  pointsToXPConversion Float    @default(0.1)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("gamification_settings")
}
